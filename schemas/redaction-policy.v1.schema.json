{
  "title": "Redaction Policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "const": "redaction-policy.v1"
    },
    "policy_id": {
      "type": "string"
    },
    "max_stdout_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "max_stderr_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "allow_full_diffs": {
      "type": "boolean"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "replacement"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "pattern_hint": {
            "type": "string"
          },
          "replacement": {
            "type": "string"
          }
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/redaction-policy.v1.schema.json"
}
