{
  "title": "Omnipull Run Index v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "source_path",
    "reports",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "omnipull-run-index.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\S.*\\S|\\S)$"
    },
    "reports": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "report_id",
          "run_id",
          "generated_at",
          "source_path"
        ],
        "properties": {
          "report_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S(?:.*\\S)?$"
          },
          "run_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S(?:.*\\S)?$"
          },
          "generated_at": {
            "type": "string",
            "format": "date-time"
          },
          "source_path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?:\\S.*\\S|\\S)$"
          }
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "does_not_execute",
        "does_not_mutate",
        "does_not_authorise_actions"
      ],
      "properties": {
        "does_not_execute": {
          "const": true
        },
        "does_not_mutate": {
          "const": true
        },
        "does_not_authorise_actions": {
          "const": true
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/omnipull-run-index.v1.schema.json"
}
