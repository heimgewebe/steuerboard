{
  "title": "Action Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "action",
    "decision",
    "assessment_ref",
    "source_refs",
    "rule_refs",
    "freshness_refs",
    "falsification_refs",
    "missing_evidence",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "action-plan.v1"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "const": "switch-main"
    },
    "assessment_ref": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": [
        "blocked",
        "not_applicable"
      ]
    },
    "blocked_because": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "rule_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "freshness_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "falsification_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "does_not_execute",
        "does_not_mutate",
        "does_not_authorise_actions"
      ],
      "properties": {
        "does_not_execute": {
          "const": true
        },
        "does_not_mutate": {
          "const": true
        },
        "does_not_authorise_actions": {
          "const": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "blocked"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "required": [
          "blocked_because"
        ],
        "properties": {
          "blocked_because": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision": {
            "const": "not_applicable"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "not": {
          "required": [
            "blocked_because"
          ]
        }
      }
    }
  ],
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/action-plan.v1.schema.json"
}
