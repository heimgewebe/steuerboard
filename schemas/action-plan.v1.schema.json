{
  "title": "Action Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "action",
    "decision",
    "would_run",
    "would_mutate",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "action-plan.v1"
    },
    "plan_id": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "repo_id": {
      "type": "string"
    },
    "assessment_ref": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": [
        "allowed",
        "blocked",
        "warn",
        "not_applicable"
      ]
    },
    "would_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "would_mutate": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_because": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safe_alternatives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rule_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "freshness_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "falsification_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "does_not_execute",
        "does_not_mutate",
        "does_not_authorise_actions"
      ],
      "properties": {
        "does_not_execute": {
          "const": true
        },
        "does_not_mutate": {
          "const": true
        },
        "does_not_authorise_actions": {
          "const": true
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/action-plan.v1.schema.json"
}
