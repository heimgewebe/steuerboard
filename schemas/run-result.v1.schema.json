{
  "title": "Run Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "redaction_verified"
  ],
  "properties": {
    "schema_version": {
      "const": "run-result.v1"
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "success",
        "failure",
        "blocked"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_verified": {
      "type": "boolean"
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/run-result.v1.schema.json"
}
