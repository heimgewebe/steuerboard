{
  "title": "Run Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "redaction_verified"
  ],
  "properties": {
    "schema_version": {
      "const": "run-result.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "plan_ref": {
      "type": "string",
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "plan_content_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "status": {
      "enum": [
        "success",
        "failure",
        "blocked"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "redaction_verified": {
      "type": "boolean"
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "action": {
      "type": "string",
      "enum": [
        "git-status-read-only",
        "git-pull-ff-only"
      ]
    },
    "preflight_for_action_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_ref",
        "plan_action",
        "plan_content_sha256"
      ],
      "properties": {
        "plan_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S(?:.*\\S)?$"
        },
        "plan_action": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S(?:.*\\S)?$"
        },
        "plan_content_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/run-result.v1.schema.json"
}
