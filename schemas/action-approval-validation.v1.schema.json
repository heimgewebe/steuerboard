{
  "title": "Action Approval Validation v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "validation_id",
    "plan_ref",
    "approval_ref",
    "action",
    "checked_at",
    "binding_state",
    "blocked_because",
    "source_refs",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "action-approval-validation.v1"
    },
    "validation_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "plan_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "approval_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "action": {
      "enum": [
        "git-pull-ff-only"
      ]
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "binding_state": {
      "enum": [
        "binding_valid",
        "binding_invalid"
      ]
    },
    "blocked_because": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^\\S(?:.*\\S)?$"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^\\S(?:.*\\S)?$"
      }
    },
    "explanation": {
      "type": "string"
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "does_not_execute",
        "does_not_mutate",
        "does_not_authorise_execution",
        "does_not_create_runner"
      ],
      "properties": {
        "does_not_execute": {
          "const": true
        },
        "does_not_mutate": {
          "const": true
        },
        "does_not_authorise_execution": {
          "const": true
        },
        "does_not_create_runner": {
          "const": true
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/action-approval-validation.v1.schema.json"
}
