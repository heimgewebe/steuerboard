{
  "title": "Local Config v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "host",
    "paths",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "const": "local-config.v1"
    },
    "host": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S(?:.*\\S)?$"
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "canonical_repo_roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S(?:.*\\S)?$"
          }
        },
        "excluded_repo_roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S(?:.*\\S)?$"
          }
        }
      }
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "favorite_repo_paths": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S(?:.*\\S)?$"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_mutating_actions": {
          "type": "boolean"
        },
        "allow_branch_switch": {
          "type": "boolean"
        },
        "allow_network_fetch": {
          "type": "boolean"
        }
      },
      "required": [
        "allow_mutating_actions",
        "allow_branch_switch",
        "allow_network_fetch"
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/local-config.v1.schema.json"
}
