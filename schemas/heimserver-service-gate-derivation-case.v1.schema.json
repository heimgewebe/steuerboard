{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/heimserver-service-gate-derivation-case.v1.schema.json",
  "title": "heimserver-service-gate-derivation-case.v1",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "description",
    "inputs",
    "expected_assessment_ref"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "heimserver-service-gate-derivation-case.v1"
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "object",
      "required": [
        "server_facts_ref",
        "expectation_ref",
        "service_evidence_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "server_facts_ref": {
          "type": "object",
          "required": [
            "path",
            "sha256"
          ],
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        },
        "expectation_ref": {
          "type": "object",
          "required": [
            "path",
            "sha256"
          ],
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        },
        "service_evidence_ref": {
          "type": "object",
          "required": [
            "path",
            "sha256"
          ],
          "additionalProperties": false,
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          }
        }
      }
    },
    "expected_assessment_ref": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
