{
  "title": "Omnipull Report Reference v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "run_id",
    "source_path",
    "selected_by"
  ],
  "properties": {
    "schema_version": {
      "const": "omnipull-report-ref.v1"
    },
    "report_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S(?:.*\\S)?$"
    },
    "source_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?:\\S.*\\S|\\S)$"
    },
    "selected_by": {
      "type": "string",
      "enum": [
        "latest.generated_at"
      ]
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/omnipull-report-ref.v1.schema.json"
}
