{
  "title": "Repo Assessment v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assessment_id",
    "observation_ref",
    "derived_status",
    "source_refs",
    "decision_state"
  ],
  "properties": {
    "schema_version": {
      "const": "repo-assessment.v1"
    },
    "assessment_id": {
      "type": "string",
      "minLength": 1
    },
    "observation_ref": {
      "type": "string",
      "minLength": 1
    },
    "derived_status": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_state": {
      "type": "string",
      "enum": ["action_blocked", "evidence_missing", "assessment_clear"],
      "description": "Assessment outcome — not an action authorisation. Contractually enforced enum: action_blocked, evidence_missing, assessment_clear."
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "unknown"],
      "description": "Assessed risk level derived from observation and scope."
    },
    "skip_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Normalised reason codes explaining why action is blocked or deferred."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence in the derived_status, 0..1."
    },
    "rule_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional references to the rules that produced this assessment."
    },
    "freshness_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional references to freshness model entries used."
    },
    "falsification_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional references to falsification cases that motivated the rules."
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/repo-assessment.v1.schema.json"
}
