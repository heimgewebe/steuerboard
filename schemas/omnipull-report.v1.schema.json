{
  "title": "Omnipull Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "run_id",
    "generated_at",
    "source_path",
    "repos",
    "boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "omnipull-report.v1"
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "repos": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo_id",
          "path",
          "status",
          "skip_reasons",
          "source_refs",
          "freshness_refs",
          "falsification_refs",
          "missing_evidence"
        ],
        "properties": {
          "repo_id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1,
            "enum": [
              "non_default_branch",
              "dirty_worktree",
              "no_upstream",
              "remote_unreachable",
              "ff_only_not_possible",
              "default_branch_unknown",
              "repo_not_in_scope",
              "permission_denied"
            ]
          },
          "skip_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "freshness_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "falsification_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missing_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "does_not_execute",
        "does_not_mutate",
        "does_not_authorise_actions"
      ],
      "properties": {
        "does_not_execute": {
          "const": true
        },
        "does_not_mutate": {
          "const": true
        },
        "does_not_authorise_actions": {
          "const": true
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/omnipull-report.v1.schema.json"
}
