{
  "title": "Repo Inventory v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "source_refs",
    "observed_at",
    "host",
    "repos"
  ],
  "properties": {
    "schema_version": {
      "const": "repo-inventory.v1"
    },
    "inventory_id": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "host": {
      "type": "string",
      "minLength": 1
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "is_git_repo",
          "scope",
          "scope_reason",
          "git_toplevel"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "is_git_repo": {
            "type": "boolean"
          },
          "scope": {
            "type": "string",
            "enum": [
              "scope_canonical",
              "scope_shadow",
              "scope_backup",
              "scope_gdrive",
              "scope_unknown",
              "scope_excluded"
            ]
          },
          "scope_reason": {
            "type": "string",
            "minLength": 1
          },
          "git_toplevel": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/steuerboard/schemas/repo-inventory.v1.schema.json"
}
